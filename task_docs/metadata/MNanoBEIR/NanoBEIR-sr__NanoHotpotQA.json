        "query": {
          "text": "Ko je dao Kaganoiju Šigemočiju oštricu koju je napravila osoba koja je osnovala Muramasa školu?",
          "full_chars": 95,
          "limit_chars": 500,
          "truncated": false
        },
        "positive_document": {
          "text": "Kaganoi Shigemochi (加賀井 重望, 1561 – 27. avgust 1600) bio je japanski samuraj iz perioda Azuči-Momojama, koji je služio klanu Oda. Vladao je dvorcem Kaganoi. Tokom Bitke kod Komakija i Nagakutea, Shigemochi se borio pod komandom svog oca Shigemunea, koji je bio pridodat snagama Oda Nobukatsua. Ubrzo nakon toga, dvorac Kaganoi je opkoljen od strane snaga Tojotomi Hidejošija; Shigemune se predao, a Shigemochi je zaposlen od strane Hidejošija kao glasnik, primajući platu od 10.000 \"koku-a\". Takođe je posedovao mač koji je načinio Muramasa, koji mu je Hidejošii poklonio 1598. godine.",
          "full_chars": 584,
          "limit_chars": 1000,
          "truncated": false
        }
      },
      {
        "query_id": "5a738fe855429908901be2fb",
        "document_id": "17279901",
        "query": {
          "text": "Koji film je napisao i režirao Joby Harold, a muziku komponovao Samuel Sim?",
          "full_chars": 75,
          "limit_chars": 500,
          "truncated": false
