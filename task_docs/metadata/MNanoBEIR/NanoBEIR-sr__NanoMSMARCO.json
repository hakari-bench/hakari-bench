        "query_id": "1049867",
        "document_id": "7946528",
        "query": {
          "text": "Ko je pevao pesmu \"Here I Go Again\"?",
          "full_chars": 36,
          "limit_chars": 500,
          "truncated": false
        },
        "positive_document": {
          "text": "Za druge upotrebe, pogledajte Here I Go Again (razvrstavanje). \"Here I Go Again\" je pesma britanskog rok benda Whitesnake. Prvobitno objavljena na njihovom albumu iz 1982. godine Saints & Sinners, pesma je ponovo snimljena za njihov istoimeni album iz 1987. godine Whitesnake. Iste godine pesma je ponovo snimljena u novoj radio-miks verziji.",
          "full_chars": 342,
          "limit_chars": 1000,
          "truncated": false
        }
      },
      {
        "query_id": "1027209",
        "document_id": "7831679",
        "query": {
          "text": "Koga Kameron Bojs glumi u seriji \"Liv i Madi\"?",
          "full_chars": 46,
          "limit_chars": 500,
          "truncated": false
