        "query_id": "d23a86bb3c47b0f3f3b74824adf09d8e156bca40bace65059ffec5c0a5c0026a",
        "document_id": "1fd2290f0eb02cdeabec195db5c26738c6f2755b0dd903551705627eca3ff245",
        "query": {
          "text": "ഈസ്റ്റ് ഇന്ത്യാ കമ്പനി കലാപം അടിച്ചമർത്തപ്പെട്ടതിനെ തുടർന്ന്,രാജ്യം വിട്ട് തന്റെ പുത്രന്മാരെ വെടിവെച",
          "full_chars": 148,
          "limit_chars": 100,
          "truncated": true
        },
        "positive_document": {
          "text": "1803-ലെ ദില്ലി യുദ്ധത്തിൽ മറാഠരെ പരാജയപ്പെടുത്തി ബ്രിട്ടീഷുകാർ ഉത്തരേന്ത്യയുടെ നിയന്ത്രണം കൈയടക്കി. മുഗളരുടെ സംരക്ഷകരായി ദില്ലിയിലെത്തിയ ബ്രിട്ടീഷുകാർ തുടക്കത്തിൽ ചക്രവർത്തിയോട് ബഹുമാനപൂർവ്വമായിരുന്നു",
          "full_chars": 1588,
          "limit_chars": 200,
          "truncated": true
        }
      },
      {
        "query_id": "35ae92d6de2a5d28ce90287d45125b43f08a46256a4bb523ce605b363fede6c2",
        "document_id": "faf88ab82e44a6274e37a7cc8812069b08b24eb9ff60802dffeb237626d174ed",
        "query": {
          "text": "വർഷങ്ങളുടെ പോരാട്ടത്തിന് ശേഷം, ബ്രിട്ടീഷുകാരിൽ നിന്ന് ഇന്ത്യയ്ക്ക് സ്വാതന്ത്ര്യം ലഭിച്ചതെന്ന്?",
          "full_chars": 94,
          "limit_chars": 100,
          "truncated": false
        },
        "positive_document": {
          "text": "1857-ൽ ഇംഗ്ലീഷ്‌ ഈസ്റ്റിന്ത്യാ കമ്പനിക്കു നേരെയുണ്ടായ കലാപമാണ്‌ യൂറോപ്യൻ അധിനിവേശത്തിനു നേരെ ഇന്ത്യക്കാർ നടത്തിയ പ്രധാന ചെറുത്തുനിൽപ്പ്‌ ശ്രമം. ഒന്നാം ഇന്ത്യൻ സ്വാതന്ത്ര്യ സമരം എന്നറിയപ്പെടുന്ന ഈ കലാപ",
          "full_chars": 2424,
          "limit_chars": 200,
          "truncated": true
        }
      },
      {
        "query_id": "11e08f0ba3e1a481dcafb71f9de3aaa79f9e28699f1b6eb95c42827dc69c3753",
        "document_id": "132f0dca798f20dea7d388b7e9b47c7f10f1005c3fe552d0a08fd117d5fb8ccc",
        "query": {
          "text": "ആർ കെ നാരായണന്റെ ആദ്യ കൃതി ഏത് ?",
          "full_chars": 32,
          "limit_chars": 100,
          "truncated": false
        },
        "positive_document": {
          "text": "ആർ. കെ. നാരായണൻ ബ്രിട്ടീഷ് ഇന്ത്യയിലെ മദ്രാസിൽ (ഇപ്പോൾ ചെന്നൈ, തമിഴ്‌നാട്) ഒരു അയ്യർ വടാമ തമിഴ് ബ്രാഹ്മണ കുടുംബത്തിൽ 1906 ഒക്ടോബർ 10-ന് ജനിച്ചു. ആറ് ആൺമക്കളും രണ്ട് പെൺമക്കളുമുള്ള ഒരു കുടുംബത്തിലെ എട്",
          "full_chars": 4050,
          "limit_chars": 200,
          "truncated": true
        }
      },
      {
        "query_id": "f1e8bc2be71f20ae04e1f88d9293996838678b66f7533cef504dce942fb63e1a",
        "document_id": "ae1ecac2b4be0738c0999c977df2910708fb17109ad4b5dc7f44588c74c14ec7",
        "query": {
          "text": "അലാവുദ്ദീൻ ഖൽജി നിർമ്മിച്ച ഒരു വലിയ കവാടം ഏതായിരുന്നു?",
          "full_chars": 54,
          "limit_chars": 100,
          "truncated": false
        },
        "positive_document": {
          "text": "1199-ൽ ദില്ലി സുൽത്താനായിരുന്ന ഖുത്ബ്ദീൻ ഐബക് ആയിരുന്നു ഈ മിനാറിന്റെ ആദ്യ നില പണികഴിപ്പിച്ചത്. സുൽത്താൻ ഇൽത്തുമിഷ്, 1229-ഓടെ മറ്റു നാലുനിലകളുടെ പണി പൂർത്തീകരിച്ചു. ഗോറി സാമ്രാജ്യത്തിന്റെ കാലത്ത് അഫ്ഗാ",
          "full_chars": 1608,
          "limit_chars": 200,
          "truncated": true
        }
      },
      {
