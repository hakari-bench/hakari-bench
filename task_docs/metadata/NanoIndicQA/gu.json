        "query": {
          "text": "ક્યાં શહેરને \"માન્ચેસ્ટર ઓફ ધ ઇસ્ટ\" તરીકે પણ ઓળખવામાં આવતું હતું?",
          "full_chars": 65,
          "limit_chars": 500,
          "truncated": false
        },
        "positive_document": {
          "text": "અંગ્રજોના શાસનકાળ દરમિયાન અમદાવાદ એક મુખ્ય નગર બની ગયું. અહીં તેમણે કોર્ટ, નગરપાલિકા વગેરે સ્થાપ્યાં. કાપડની મિલોને કારણે અમદાવાદ 'પૂર્વનું માંચેસ્ટર' પણ કહેવાતું હતું. મે ૧૯૬૦થી નવા બનેલા ગુજરાત રાજ્યનું પાટનગર બન્યુ. ગાંધીનગર નવું પાટનગર બનવા છતાં અમદાવાદની મહત્તા એવી જ રહી છે. ૧૯૭૪માં એલ. ડી. કોલેજ ઓફ એન્જિનિયરિંગના છાત્રાલયના ભોજનાલયમાં દરમાં ૨૦%નો વધારો થતા તેનો વિરોધ શરૂ થયો, જે નવનિર્માણ આંદોલનમાં પરિણમ્યો અને ભારતના ઈતિહાસમાં સૌપ્રથમ (અને માત્ર એકવાર) ચૂંટાયેલા મુખ્યમંત્રી - ચીમનભાઈ પટેલે આંદોલનને કારણે રાજીનામું આપવું પડ્યું.",
          "full_chars": 540,
          "limit_chars": 1000,
          "truncated": false
        }
