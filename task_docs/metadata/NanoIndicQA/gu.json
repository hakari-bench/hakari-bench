      {
        "query_id": "29ccca2aa54b381314d62a40aedde17394d1d7e7635473b853c4ebd0f60ade63",
        "document_id": "4d4522cab07756466d3c92c9291dfea27c4564397b238f21cfbedad84a7ec0c5",
        "query": {
          "text": "ક્યાં શહેરને \"માન્ચેસ્ટર ઓફ ધ ઇસ્ટ\" તરીકે પણ ઓળખવામાં આવતું હતું?",
          "full_chars": 65,
          "limit_chars": 100,
          "truncated": false
        },
        "positive_document": {
          "text": "અંગ્રજોના શાસનકાળ દરમિયાન અમદાવાદ એક મુખ્ય નગર બની ગયું. અહીં તેમણે કોર્ટ, નગરપાલિકા વગેરે સ્થાપ્યાં. કાપડની મિલોને કારણે અમદાવાદ 'પૂર્વનું માંચેસ્ટર' પણ કહેવાતું હતું. મે ૧૯૬૦થી નવા બનેલા ગુજરાત રાજ્",
          "full_chars": 540,
          "limit_chars": 200,
          "truncated": true
        }
      },
      {
        "query_id": "061f559bfa27eb70bf8f96f06083879d226833c6cb882331135368c2b9a013a6",
        "document_id": "8dcbbdc8dbe54e5f5db93af34455147438e83312ca357bcf70e3554dc72f2cdb",
        "query": {
          "text": "અન્ય મધ્યયુગીન શાસકોની જેમ કોણ એક મહાન સામ્રાજ્યવાદી હતા?",
          "full_chars": 57,
          "limit_chars": 100,
          "truncated": false
        },
        "positive_document": {
          "text": "અન્ય મધ્યયુગીન શાસકોની જેમ અકબર પણ એક મહાન સામ્રાજ્યવાદી હતો. અને તેને પોતાનુ રાજ્ય ઉત્તરે અફઘાનિસ્તાન કાશ્મીરની દક્ષિણે મૈસુર સુધી તથા પશ્ચિમે ગુજરાતની પુર્વમાં બંગાળ સુધી ફેલાવવાની મહત્વાકાંક્ષા હતી",
          "full_chars": 1639,
          "limit_chars": 200,
          "truncated": true
        }
      },
